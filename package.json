{
  "name": "ax-js",
  "version": "0.0.2",
  "description": "Client-side Gaussian process predictions mirroring Ax/BoTorch — prediction, visualization, and acquisition in the browser",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./acquisition": {
      "types": "./dist/acquisition/index.d.ts",
      "import": "./dist/acquisition/index.js",
      "require": "./dist/acquisition/index.cjs"
    },
    "./viz": {
      "types": "./dist/viz/index.d.ts",
      "import": "./dist/viz/index.js",
      "require": "./dist/viz/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node demo/build_demos.js",
    "build:lib": "tsup",
    "build:notebook": "python3 python/build_demo_notebook.py",
    "build:e2e": "python3 python/build_e2e_notebook.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eytan/ax-js.git"
  },
  "homepage": "https://github.com/eytan/ax-js",
  "bugs": {
    "url": "https://github.com/eytan/ax-js/issues"
  },
  "keywords": [
    "bayesian-optimization",
    "gaussian-process",
    "ax",
    "botorch",
    "machine-learning",
    "surrogate-model",
    "gp",
    "prediction",
    "visualization"
  ],
  "author": "Meta Platforms, Inc.",
  "license": "MIT",
  "devDependencies": {
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "chromium": "^3.0.3",
    "playwright": "^1.58.2"
  }
}
